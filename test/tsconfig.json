{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": [
      "vitest/globals",
      "node"
    ],
    "baseUrl": ".."
  },
  "include": [
    "./**/*.ts",
    "./fixtures/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}